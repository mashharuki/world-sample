{
	"name": "sample-agentkit-x402",
	"version": "1.0.0",
	"description": "World AgentKit x402 チュートリアルアプリ (TypeScript + Bun)",
	"scripts": {
		"format": "biome format --write .",
		"start": "bun run src/server.ts",
		"dev": "bun --watch src/server.ts",
		"agent": "bun run src/agent.ts",
		"gen-header": "bun run src/gen-header.ts",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"@worldcoin/agentkit-core": "^0.1.6",
		"ethers": "^6.13.0",
		"express": "^4.18.2",
		"siwe": "^2.3.2"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.10",
		"@types/express": "^4.17.21",
		"@types/node": "^20.0.0",
		"typescript": "^5.4.0"
	}
}
