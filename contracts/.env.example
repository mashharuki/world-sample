# World Chain Sepolia RPC URL
# 取得先: https://developer.worldcoin.org/ または https://alchemy.com/
WORLD_SEPOLIA_RPC_URL=https://worldchain-sepolia.g.alchemy.com/v2/YOUR_API_KEY

# デプロイに使用するウォレットの秘密鍵（0x プレフィックスなしでも可）
# World Sepolia テストETHの取得: https://faucet.worldcoin.org/
PRIVATE_KEY=your_private_key_here

# （オプション）コントラクト検証用
# World Chain Explorer: https://worldchain-sepolia.explorer.alchemy.com
WORLDCHAIN_EXPLORER_API_KEY=
